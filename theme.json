{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "760px",
			"wideSize": "1180px"
		},
		"spacing": {
			"units": [ "px", "em", "rem", "%", "vh", "vw" ],
			"spacingScale": {
				"steps": 0
			},
			"spacingSizes": [
				{ "name": "XS", "slug": "xs", "size": "12px" },
				{ "name": "S",  "slug": "s",  "size": "20px" },
				{ "name": "M",  "slug": "m",  "size": "32px" },
				{ "name": "L",  "slug": "l",  "size": "56px" },
				{ "name": "XL", "slug": "xl", "size": "88px" }
			]
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"custom": true,
			"customGradient": false,
			"palette": [
				{ "name": "Background",       "slug": "background",    "color": "#f5f0e8" },
				{ "name": "Background Alt",   "slug": "background-alt","color": "#ebe3d4" },
				{ "name": "Surface",          "slug": "surface",       "color": "#ffffff" },
				{ "name": "Ink",              "slug": "ink",           "color": "#8d6e63" },
				{ "name": "Body",             "slug": "body",          "color": "#8d6e64" },
				{ "name": "Deep Brown",       "slug": "deep-brown",    "color": "#5a4a43" },
				{ "name": "Accent",           "slug": "accent",        "color": "#10b981" },
				{ "name": "Accent Dark",      "slug": "accent-dark",   "color": "#0ea673" },
				{ "name": "Hairline",         "slug": "hairline",      "color": "#e4dccd" },
				{ "name": "Muted",            "slug": "muted",         "color": "#B8C0CC" }
			]
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"name": "Noto Serif Georgian",
					"slug": "noto-serif-georgian",
					"fontFamily": "\"Noto Serif Georgian\", \"Noto Serif\", Georgia, \"Times New Roman\", serif"
				}
			],
			"fontSizes": [
				{ "name": "Small",  "slug": "small",  "size": "14px" },
				{ "name": "Medium", "slug": "medium", "size": "17px" },
				{ "name": "Large",  "slug": "large",  "size": "20px" },
				{ "name": "H3",     "slug": "h3",     "size": "22px" },
				{
					"name": "H2",
					"slug": "h2",
					"size": "32px",
					"fluid": { "min": "24px", "max": "32px" }
				},
				{
					"name": "H1",
					"slug": "h1",
					"size": "44px",
					"fluid": { "min": "30px", "max": "44px" }
				},
				{
					"name": "Hero",
					"slug": "hero",
					"size": "56px",
					"fluid": { "min": "34px", "max": "56px" }
				}
			]
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text":       "var(--wp--preset--color--body)"
		},
		"typography": {
			"fontFamily":    "var(--wp--preset--font-family--noto-serif-georgian)",
			"fontSize":      "var(--wp--preset--font-size--medium)",
			"lineHeight":    "1.6"
		},
		"spacing": {
			"blockGap": "1.5rem"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--ink)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--accent)"
					}
				}
			},
			"h1": {
				"typography": {
					"fontFamily":    "var(--wp--preset--font-family--noto-serif-georgian)",
					"fontSize":      "var(--wp--preset--font-size--h1)",
					"fontWeight":    "700",
					"lineHeight":    "1.18",
					"letterSpacing": "-0.01em"
				},
				"color": { "text": "var(--wp--preset--color--ink)" }
			},
			"h2": {
				"typography": {
					"fontFamily":    "var(--wp--preset--font-family--noto-serif-georgian)",
					"fontSize":      "var(--wp--preset--font-size--h2)",
					"fontWeight":    "700",
					"lineHeight":    "1.18",
					"letterSpacing": "-0.01em"
				},
				"color": { "text": "var(--wp--preset--color--ink)" }
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--noto-serif-georgian)",
					"fontSize":   "var(--wp--preset--font-size--h3)",
					"fontWeight": "700",
					"lineHeight": "1.3"
				},
				"color": { "text": "var(--wp--preset--color--ink)" }
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--noto-serif-georgian)",
					"fontSize":   "15px",
					"fontWeight": "600"
				},
				"color": { "text": "var(--wp--preset--color--accent)" }
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--accent)",
					"text":       "#ffffff"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--noto-serif-georgian)",
					"fontWeight": "700",
					"fontSize":   "16px",
					"letterSpacing": "0.01em"
				},
				"border":  { "radius": "8px" },
				"spacing": { "padding": { "top": "14px", "right": "26px", "bottom": "14px", "left": "26px" } },
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--accent-dark)",
						"text":       "#ffffff"
					}
				}
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	],
	"customTemplates": [
		{ "name": "page-wide", "title": "Wide Page", "postTypes": [ "page" ] },
		{ "name": "page-legal", "title": "Legal / Long-form", "postTypes": [ "page" ] }
	]
}
